# Copy to .env.local and fill in values (never commit .env.local).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase CLI (your laptop / CI only — not read by Next.js) ──────────────
# Create a token: https://supabase.com/dashboard/account/tokens (starts with sbp_)
# Then link once: npm run supabase:link
# Push migrations: npm run db:push:yes
#
# Git Bash / macOS / Linux:
#   export SUPABASE_ACCESS_TOKEN=sbp_your_token_here
# Windows CMD:
#   set SUPABASE_ACCESS_TOKEN=sbp_your_token_here
# Windows PowerShell:
#   $env:SUPABASE_ACCESS_TOKEN="sbp_your_token_here"
#
# SUPABASE_ACCESS_TOKEN=

PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Billing cron (POST /api/cron/billing-reminders, etc.)
BILLING_CRON_SECRET=

# Internal ops: registration payment alerts (email via SendPulse external API)
ADMIN_OPS_EMAIL=

# Supabase app_settings row (not an env var): key default_registration_program_id = UUID of default programmes.price for public registration.

STRIPE_SECRET_KEY=
SENDPULSE_API_ID=
SENDPULSE_API_SECRET=

ENABLE_PAYMENTS=false
